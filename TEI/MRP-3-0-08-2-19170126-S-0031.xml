ns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0" type="person" ref="#mpr3505">Spitzmüller</tei:rs>, <tei:rs xmlns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0" type="person" ref="#mpr4527">Bobrzyński</tei:rs>, <tei:rs xmlns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0" type="person" ref="#mpr4435">Handel</tei:rs>, <tei:rs xmlns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0" type="person" ref="#mpr4542">Schenk</tei:rs>, <tei:rs xmlns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0" type="person" ref="#mpr4549">Urban</tei:rs>; <tei:choice xmlns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0"><tei:abbr>abw.</tei:abbr><tei:expan>abwesend</tei:expan></tei:choice> <tei:rs xmlns:p="https://id.acdh.oeaw.ac.at/patternmatcher" xmlns:tei="http://www.tei-c.org/ns/1.0" type="person" ref="#mpr4573">Höfer</tei:rs>.</hi></p>
